# Required: Google Gemini API Key
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Strong random value used to sign login tokens (JWT)
# Generate with: openssl rand -hex 32
ASTRA_JWT_SECRET=change_this_to_a_strong_random_secret

# Optional: Token lifetime in hours (default: 24)
ASTRA_JWT_EXPIRE_HOURS=24

# Required: PostgreSQL Database URL
ASTRA_DATABASE_URL=postgresql+psycopg2://postgres:password@postgres:5432/astra_db

# Optional: NVD API Key for enhanced CVE data (higher rate limits: 50 req/30s vs 5 req/30s)
# Get your key from: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# Optional: GitHub Personal Access Token for GitHub Security Advisories
# Without this, advisory lookups still work anonymously (60 req/hr vs 5000 req/hr with token)
# Create a token (no scopes needed) at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# Optional: Neo4j Graph Database (for persistent graph storage)
# If not set, ASTRA uses in-memory NetworkX graphs
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
